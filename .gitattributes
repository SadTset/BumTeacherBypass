# Normalize text files to LF in the repo; let Git pick text vs binary.
* text=auto

# Files that MUST keep LF even on Windows checkouts (core.autocrlf=true),
# otherwise Alpine/sh in Docker fails on \r in the shebang.
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.pdf binary
*.db binary
